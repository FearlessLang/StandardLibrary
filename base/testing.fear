StackFrame:{ .fileName: Str; .typeName: Str; .methodName: Str; .lineNumber: Nat; }
StackFrames:F[Str,Str,Str,Nat,StackFrame]{ fn,tn,mn,ln -> 
  { .fileName->fn; .typeName->tn; .methodName->mn; .lineNumber->ln;} }

UnitTests: Main{
  .main sys->Block#
    .let[mut RTestCap] ts={_TestCaps#(sys.try,ELists#)}
    .do {Block#(this.tests(ts),Void)}
    .return {ts.run};
  .tests(t: mut TestCap): mut TestCap;
  }
TestCap: Sealed{//by making it sealed we can guaranteed the output of the function is the same of the original input
  //so we can use subtyping to get more methods on that object/rely on the injected EList
  mut .let[T](f:F[T],c:TestCont[T]): mut TestCap -> c#(f#,this);
  //so .let must be just imm stuff, nothing else makes sense.
  mut .test(t: Test): mut TestCap -> t.tests this;
  mut .disabledTest(Test): mut TestCap -> this;
  mut .check(Check): mut TestCap;
  mut .disabledCheck(Check): mut TestCap -> this;
  }
TestCont[T]: { #(t: T, self: mut TestCap): mut TestCap }

_TestCaps: {
  #(try: mut CapTry, ts: mut EList[CheckInfo]): mut RTestCap -> mut RTestCap:TestCap{'self
    .check c -> Block#(
      ts.add(CheckInfos#(c,c._fetchTrace{ try.currentStackTrace })),
      self);
    mut .run: Void -> Void;//TODO:later
    }
  }
Check:{ #:Void; ._fetchTrace(f: mut MF[List[StackFrame]]): List[StackFrame]->f#;}
CheckInfos:F[Check,List[StackFrame],CheckInfo]{c,st->CheckInfo:{
  .check:Check->c; .stackTrace:List[StackFrame]->st;}}
Test: { .tests(t: mut TestCap): mut TestCap; }

