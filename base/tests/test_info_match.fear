InfoMatchTests: F[Tests, Tests] {::
  .testSuite InfoExtractorTests
  }

InfoExtractorTests: F[Tests, Tests] {::
  .test(
    _ExampleInfos.first ~ > `Count`
      .isMsg => {::.natExact!}! .assertEq 2
    )
  .test(
    _ExampleInfos.first ~ > `Doesn't Exist` => {::}
      .isEmpty .assertTrue
    )
  .test(
    _ExampleInfos.simple ~ .msgMatch{::.contains `World`} => {::}!
      .assertEq `Hello World`
    )
  .test(
    _ExampleInfos.simple ~ .msgMatch{_ -> False} => {::}.isEmpty
    .assertTrue
    )
  .test(
    _ExampleInfos.first ~ > `Messages` > 1 > `Type` .isMsg => {::}!
      .assertEq(`Warning`)
    )
  }

_ExampleInfos: {
  .first: Info -> Infos.map(
    `User`, Infos.map(
      `Name`, Infos.msg(`Alice`),
      `Role`, Infos.msg(`Admin`),
      `Active`, Infos.msg(`true`)
      ),
    `Messages`, Infos.list(
      Infos.map(
        `Type`, Infos.msg(`Error`),
        `Content`, Infos.msg(`Failed to load resource`),
        `Code`, Infos.msg(`500`)
        ),
      Infos.map(
        `Type`, Infos.msg(`Warning`),
        `Content`, Infos.msg(`Low memory`),
        `Code`, Infos.msg(`301`)
        )
      ),
    `Count`, Infos.msg(`2`)
    );

  .simple: Info -> Infos.msg `Hello World`;
  .list: Info -> Infos.list(`First`, `Second`);
}