SetFileTests: F[Tests, Tests] {::
  .testSuite SetTests
  .testSuite _SetTests
  }

SetTests: F[Tests, Tests] {::
  .test(Sets#({::}, 1, 2) ++ (Sets#({::}, 2, 3), {::})
        .assertEq({::}, Sets#({::}, 1, 2, 3)))
  .test(Sets#({::}, 1, 2).union(Sets#({::}, 2, 3))
        .assertEq({::}, Sets#({::}, 1, 2, 3)))
  .test(Sets#({::}, 1, 2) ++ (Sets#({::}, 2, 3))
        .str .assertEq "{1, 2, 3}")
  .test(Sets#({::}, 1, 2) & (Sets#({::}, 2, 3), {::})
        .assertEq({::}, Sets#({::}, 2)))
  .test(Sets#({::}, 1,2,3) & (Sets#({::})) .isEmpty .assertTrue)
  .test(Sets#({::}, 1, 2).intersection(Sets#({::}, 2, 3))
        .assertEq({::}, Sets#({::}, 2)))
  .test(Sets#({::}, 1, 2) & (Sets#({::}, 2, 3))
        .assertEq({::}, Sets#({::}, 2)))
  .test(Sets#({::}, 1, 2, 3) -- (Sets#({::}, 2))
        .assertEq({::}, Sets#({::}, 1, 3)))
  .test(Sets#({::}, 1, 2, 3).symmetricDifference(Sets#({::}, 2, 4), {::})
        .assertEq({::}, Sets#({::}, 1, 3, 4)))
  .test(Sets#({::}, 1, 2, 3).symmetricDifference(Sets#({::}, 2, 4))
        .assertEq({::}, Sets#({::}, 1, 3, 4)))
  .test(Sets#({::}, 1, 2, 3).isSuperset(Sets#({::}, 1, 2)) .assertTrue)
  .test(Sets#({::}, 1, 2).isSuperset(Sets#({::}, 1, 2, 3)) .assertFalse)
  .test(Sets#({::}, 1, 2).isSubset(Sets#({::}, 1, 2, 3)) .assertTrue)
  .test(Sets#({::}, 1, 2, 3).isSubset(Sets#({::}, 1, 2)) .assertFalse)
  .test(Sets#({::}, 1, 2).isDisjoint(Sets#({::}, 3, 4)) .assertTrue)
  .test(Sets#({::}, 1, 2).isDisjoint(Sets#({::}, 2, 3)) .assertFalse)
  .test(Sets#({::}, +1, +2).isDisjoint(Sets#({::}, -3, -4), {::.imm.abs}) .assertTrue)
  .test(Sets#({::}, +1, +2).isDisjoint(Sets#({::}, -1, -3), {::.imm.abs}) .assertFalse)
  .test(Sets#({::}, 1, 2, 3).flow.list .assertEq({::}, Lists#(1, 2, 3)))
  .test(Sets#({::}, 1, 2, 3).seqFlow.list .assertEq({::}, Lists#(1, 2, 3)))
  }

_SetTests: F[Tests, Tests] {::
  .test(Sets#[Int, Nat]({::.imm.abs}, -1).contains(+1) .assertTrue)
  .test(Sets#({::}, 1, 2, 3).size .assertEq 3)
  .test(Sets#[Nat, Nat]({::}).size .assertEq 0)
  .test(Sets#[Nat, Nat]({::}).isEmpty .assertTrue)
  .test(Sets#({::}, 1).isEmpty .assertFalse)
  .test(Sets#[Nat, Nat]({::}).notEmpty .assertFalse)
  .test(Sets#({::}, 1).notEmpty .assertTrue)
  .test(Sets#({::}, 1).contains(1) .assertTrue)
  .test(Sets#({::}, 0).contains(1) .assertFalse)
  .test(Sets#({::.imm.abs}, +1, -2).get(-1)! .assertEq +1)
  .test(Sets#({::}, 1, 2).get(3).isEmpty .assertTrue)
  .test(Sets#({::}, 1) + 2 .assertEq({::}, Sets#({::}, 1, 2)))
  .test(Sets#({::.imm.abs}, +1) + -1 .assertEq({::}, Sets#({::.imm.abs}, +1)))
  .test(Sets#({::}, 2, 3) - 2 - 3 .isEmpty .assertTrue)
  .test(Sets#({::}, 1) - 2 .assertEq({::}, Sets#({::}, 1)))
  .test(Sets#({::}, 1, 2, 3).containsAll(Sets#({::}, 1, 2)) .assertTrue)
  .test(Sets#({::}, 1, 2).containsAll(Sets#({::}, 1, 2, 3)) .assertFalse)
  .test(Sets#({::}, +1, +2).containsAll(Sets#({::}, -1, -2), {::.imm.abs}) .assertTrue)
  .test(Sets#({::}, +1, +2).containsAll(Sets#({::}, -1, -3), {::.imm.abs}) .assertFalse)
  .test(Sets#({::}, 1, 2, 3).isSuperset(Sets#({::}, 1, 2)) .assertTrue)
  .test(Sets#({::}, 1, 2).isSuperset(Sets#({::}, 1, 2, 3)) .assertFalse)
  .test(Sets#({::}, +1, +2).isSuperset(Sets#({::}, -1, -2), {::.imm.abs}) .assertTrue)
  .test(Sets#({::}, +1, +2).isSuperset(Sets#({::}, -1, -3), {::.imm.abs}) .assertFalse)
  .test(Sets#({::}, 1, 2).isSubset(Sets#({::}, 1, 2, 3)) .assertTrue)
  .test(Sets#({::}, 1, 2, 3).isSubset(Sets#({::}, 1, 2)) .assertFalse)
  .test(Sets#({::}, -1, -2).isSubset(Sets#[Int, Nat]({::.imm.abs}, +1, +2), {::.imm.abs}) .assertTrue)
  .test(Sets#({::}, -1, -3).isSubset(Sets#[Int, Nat]({::.imm.abs}, +1, +2), {::.imm.abs}) .assertFalse)
  .test(Sets#({::}, 1, 2).isDisjoint(Sets#({::}, 3, 4)) .assertTrue)
  .test(Sets#({::}, 1, 2).isDisjoint(Sets#({::}, 2, 3)) .assertFalse)
  .test(Sets#({::}, +1, -2, +3)
        .distinctBy{::.imm.sign}
        .str{::} .assertEq "{+1, -2}")
  .test(Sets#({::}, -1, +2, -3).str{::.imm.abs} .assertEq "{1, 2, 3}")
  .test(Sets#({::}, -1, +2, -3).str .assertEq "{-1, +2, -3}")
  .test(Sets#({::.imm.abs}, -1, +2, -3).str .assertEq "{1, 2, 3}")
  .test(Sets#[Int,Int]({::}).str .assertEq "{}")
  .test(Sets#({::}, 1, 2).info{::} ~ .isList => {l -> l.assertEq({::}, Lists#(1.info, 2.info))}!)
  .test(Sets#[Nat, Nat]({::}).cmp({::}, Sets#({::}, 1, 2, 3), Sets#({::}, 2, 3, 1), {.eq -> 0; .lt -> 1; .gt -> 2}) .assertEq 0)
  .test(Sets#[Nat, Nat]({::}).cmp({::}, Sets#({::}, 3, 1, 2), Sets#({::}, 0, 1, 2, 3), {.eq -> 0; .lt -> 1; .gt -> 2}) .assertEq 1)
  .test(Sets#[Nat, Nat]({::}).cmp({::}, Sets#({::}, 1, 2, 3), Sets#({::}, 1, 2), {.eq -> 0; .lt -> 1; .gt -> 2}) .assertEq 2)
  .test(Sets#[Nat,Nat]({::}).cmp({::}, Sets#({::}, 1, 2, 3), Sets#({::}, 2, 3, 1), {.eq -> 0; .lt -> 1; .gt -> 2}) .assertEq 0)
  .test(Sets#[Nat,Nat]({::}).cmp({::}, Sets#({::}, 3, 1, 2), Sets#({::}, 0, 1, 2, 3), {.eq -> 0; .lt -> 1; .gt -> 2}) .assertEq 1)
  .test(Sets#[Nat,Nat]({::}).cmp({::}, Sets#({::}, 1, 2, 3), Sets#({::}, 1, 2), {.eq -> 0; .lt -> 1; .gt -> 2}) .assertEq 2)
  .test(Sets#[Int,Int]({::.imm.abs.int}).cmp(Sets#({::}, +1, +2, +3), Sets#({::}, -2, -3, -1), {.eq -> 0; .lt -> 1; .gt -> 2}) .assertEq 0)
  .test(Sets#[Int,Nat]({::.imm.abs}).cmpWithHash(Sets#({::}, +1, +2, +3), Sets#({::}, -2, -3, -1), {.eq -> 0; .lt -> 1; .gt -> 2}) .assertEq 0)
  }